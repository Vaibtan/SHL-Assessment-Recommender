# SHL Assessment Recommender — environment variables.
# Copy this file to `.env` (project root) and fill in your values.
#
# CREDENTIALS — pick ONE of these auth modes:
#
# 1. Vertex AI with API key (recommended once both APIs are enabled):
#    GOOGLE_CLOUD_PROJECT=shl-recommender-495908
#    GOOGLE_CLOUD_LOCATION=us-central1
#    GCP_API_KEY=<your-api-key>
#
# 2. Vertex AI with Application Default Credentials (no key needed):
#    Run `gcloud auth application-default login` first, then set:
#    GOOGLE_CLOUD_PROJECT=shl-recommender-495908
#    GOOGLE_CLOUD_LOCATION=us-central1
#
# 3. Google AI Studio (Generative Language API) with API key:
#    GCP_API_KEY=<your-api-key>
#    # Don't set GOOGLE_CLOUD_PROJECT — leaves us on the AI Studio surface.
#
# Aliases recognized for the API key (any of these works):
#    GCP_API_KEY  GOOGLE_API_KEY  GEMINI_API_KEY

GCP_API_KEY=
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1


# -----------------------------------------------------------------------------
# MODEL SELECTION (everything below has a sensible default; uncomment to override)
# -----------------------------------------------------------------------------

# Generation models — used by router + handlers.
# SHL_ROUTER_MODEL=gemini-2.5-flash
# SHL_HANDLER_MODEL=gemini-2.5-flash

# Embedding model + dimensionality (Matryoshka).
# SHL_EMBEDDING_MODEL=gemini-embedding-001
# SHL_EMBEDDING_DIMS=768
# SHL_EMBEDDING_BATCH_SIZE=32


# -----------------------------------------------------------------------------
# SAMPLING TEMPERATURES (per call site)
# -----------------------------------------------------------------------------

# SHL_ROUTER_TEMPERATURE=0.0       # Deterministic policy classification.
# SHL_RECOMMEND_TEMPERATURE=0.1    # Slight variation in reply prose; near-deterministic ID picks.
# SHL_REFINE_TEMPERATURE=0.1
# SHL_COMPARE_TEMPERATURE=0.2
# SHL_CLARIFY_TEMPERATURE=0.3      # Natural variation across clarifying questions.
# SHL_TOP_P=0.95


# -----------------------------------------------------------------------------
# RUNTIME
# -----------------------------------------------------------------------------

# LOG_LEVEL=INFO
# SHL_INDEX_DIR=  # override path to data/build (default: <project>/data/build)
# SHL_LLM_TIMEOUT_SECONDS=10.0
# SHL_REQUEST_TIMEOUT_SECONDS=28.0
